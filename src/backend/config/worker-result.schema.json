{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "outcome",
    "summary",
    "filesChanged",
    "verification",
    "providerReference",
    "metadata"
  ],
  "properties": {
    "outcome": {
      "description": "Use succeeded when the requested work is complete and confidently verified. Use needs-review only when a specific user decision or action is required before completion; optional review of finished work is still succeeded.",
      "enum": ["succeeded", "needs-review", "failed", "timed-out", "cancelled"]
    },
    "summary": {"type": "string"},
    "filesChanged": {"type": "array", "items": {"type": "string"}},
    "verification": {"type": "array", "items": {"type": "string"}},
    "providerReference": {"type": ["string", "null"]},
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "properties": {}
    }
  }
}
