// === dev-loop rules start (managed by the dev-loop repo) ===
// All dev-loop data lives under /dev-loop/** in the shared database.
// Access is hardcoded to tiago's account; the scheduled agent uses the
// Admin SDK and bypasses these rules entirely.
match /dev-loop/{document=**} {
  allow read, write: if request.auth != null
    && request.auth.token.email == 'tsomda@gmail.com'
    && request.auth.token.email_verified == true;
}
// === dev-loop rules end ===
