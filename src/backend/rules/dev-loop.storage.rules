// === dev-loop rules start (managed by the dev-loop repo) ===
// Message attachments: dev-loop/attachments/{itemId}/{msgId}/{filename}
match /dev-loop/{allPaths=**} {
  allow read, write: if request.auth != null
    && request.auth.token.email == 'tsomda@gmail.com'
    && request.auth.token.email_verified == true;
}
// === dev-loop rules end ===
